#include <WiFi.h>
#include <HTTPClient.h>
#include "HX711.h"

// ================= DEVICE IDENTITY =================
const char* DEVICE_ID = "ESP1";

// ================= FIREBASE REALTIME DATABASE =================
const char* RTDB_URL = "https://hospital-dashboard-d5d1b-default-rtdb.asia-southeast1.firebasedatabase.app/";

// ================= VARIABLES =================
float D          = 0;      // Weight in kg
float B          = 420.0;  // Calibration factor
float C          = 1.0;    // Reference full bag (kg)
float percentage = 0.0;
bool  isMuted    = false;

// ================= PINS =================
#define DT         18
#define SCK        19
#define LED_GREEN  15
#define LED_RED     2
#define BUZZER      4

// ================= WIFI =================
const char* ssid     = "Wokwi-GUEST";
const char* password = "";

HX711 scale;

// ===== Blink Control (Non-blocking) =====
unsigned long previousBlink = 0;
const int     blinkInterval = 300;
bool          redState      = false;

// ===== Upload Interval =================
const unsigned long UPLOAD_INTERVAL = 5000;  // 5 seconds
unsigned long lastUpload = 0;

// =========================================================
void setup() {
  Serial.begin(115200);
  delay(2000);

  Serial.println("=== LPG BAG MONITOR BOOTING ===");

  pinMode(LED_GREEN, OUTPUT);
  pinMode(LED_RED,   OUTPUT);
  pinMode(BUZZER,    OUTPUT);

  digitalWrite(LED_GREEN, LOW);
  digitalWrite(LED_RED,   LOW);
  noTone(BUZZER);

  // -------- HX711 Setup --------
  Serial.println("[SCALE] Initializing HX711...");
  scale.begin(DT, SCK);
  delay(2000);
  scale.set_scale(B);

  Serial.println("[SCALE] Ensure scale is EMPTY. Taring in 5 seconds...");
  delay(5000);
  scale.tare();
  Serial.println("[SCALE] Tare complete. System Ready.");

  // -------- WiFi Setup --------
  Serial.print("[WIFI]  Connecting to ");
  Serial.print(ssid);
  Serial.print(" ");
  WiFi.begin(ssid, password);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    attempts++;
    if (attempts > 40) {
      Serial.println("\n[WIFI]  ❌ Failed to connect. Restarting...");
      ESP.restart();
    }
  }

  Serial.println();
  Serial.println("[WIFI]  ✅ Connected!");
  Serial.print("[WIFI]  IP Address : ");
  Serial.println(WiFi.localIP());
  Serial.print("[WIFI]  Signal (RSSI): ");
  Serial.print(WiFi.RSSI());
  Serial.println(" dBm");
  Serial.println("================================");
}

// =========================================================
//  Helper — PUT or POST to Firebase RTDB
// =========================================================
int firebaseRequest(const String& path, const String& json, bool usePut) {
  HTTPClient http;
  String url = String(RTDB_URL) + path + ".json";

  Serial.print("[HTTP]  URL : ");
  Serial.println(url);
  Serial.print("[HTTP]  Payload : ");
  Serial.println(json);

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  int code = usePut ? http.PUT(json) : http.POST(json);

  if (code < 0) {
    Serial.print("[HTTP]  ❌ Error: ");
    Serial.println(http.errorToString(code));
  } else {
    Serial.print("[HTTP]  Response Code: ");
    Serial.println(code);
  }

  http.end();
  return code;
}

// =========================================================
void loop() {

  // -------- WiFi Watchdog --------
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[WIFI]  ⚠️  Connection lost! Reconnecting...");
    WiFi.disconnect();
    WiFi.begin(ssid, password);
    int wait = 0;
    while (WiFi.status() != WL_CONNECTED && wait < 20) {
      delay(500);
      Serial.print(".");
      wait++;
    }
    if (WiFi.status() == WL_CONNECTED) {
      Serial.println("\n[WIFI]  ✅ Reconnected!");
    } else {
      Serial.println("\n[WIFI]  ❌ Reconnect failed. Will retry next loop.");
    }
  }

  // -------- Read Weight --------
  if (scale.is_ready()) {
    D = max(0.0f, scale.get_units(20));
    Serial.println("----------------------------------");
    Serial.print("[SCALE] Weight     : ");
    Serial.print(D, 3);
    Serial.println(" kg");
    Serial.print("[SCALE] Percentage : ");
    Serial.print(percentage, 1);
    Serial.println(" %");
  } else {
    Serial.println("[SCALE] ⚠️  HX711 not ready, skipping read.");
  }

  percentage = (D / C) * 100.0;

  // -------- Status Indicator --------
  if (D >= 1.0) {
    Serial.println("[STATUS] 🟢 NORMAL");
    digitalWrite(LED_GREEN, HIGH);
    digitalWrite(LED_RED,   LOW);
    noTone(BUZZER);
    isMuted = false;
  }
  else if (D >= 0.5) {
    Serial.println("[STATUS] 🟡 LOW");
    digitalWrite(LED_GREEN, LOW);
    digitalWrite(LED_RED,   HIGH);
    noTone(BUZZER);
  }
  else {
    Serial.println("[STATUS] 🔴 CRITICAL — Buzzer active!");
    digitalWrite(LED_GREEN, LOW);
    unsigned long currentMillis = millis();
    if (currentMillis - previousBlink >= blinkInterval) {
      previousBlink = currentMillis;
      redState      = !redState;
      digitalWrite(LED_RED, redState);
    }
    if (!isMuted) tone(BUZZER, 1000);
  }

  // -------- Firebase Upload --------
  unsigned long now = millis();
  if (WiFi.status() == WL_CONNECTED && (now - lastUpload >= UPLOAD_INTERVAL)) {
    lastUpload = now;

    Serial.println("[FIREBASE] Uploading...");

    String json = "{\"weight\":"     + String(D, 3) +
                  ",\"percentage\":" + String(percentage, 1) +
                  ",\"ts\":"         + String(now) +
                  "}";

    // PUT → /devices/ESP1/latest (always overwrites current reading)
    String latestPath = "/devices/" + String(DEVICE_ID) + "/latest";
    int code1 = firebaseRequest(latestPath, json, true);
    if (code1 == 200) {
      Serial.println("[FIREBASE] ✅ latest updated.");
    } else {
      Serial.print("[FIREBASE] ❌ latest failed. Code: ");
      Serial.println(code1);
    }

    // POST → /devices/ESP1/readings (appends history entry)
    String readingsPath = "/devices/" + String(DEVICE_ID) + "/readings";
    int code2 = firebaseRequest(readingsPath, json, false);
    if (code2 == 200) {
      Serial.println("[FIREBASE] ✅ reading logged.");
    } else {
      Serial.print("[FIREBASE] ❌ reading log failed. Code: ");
      Serial.println(code2);
    }
  }

  delay(100);
}
