#include <WiFi.h>
#include <HTTPClient.h>
#include "HX711.h"
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// ================= DEVICE =================
const char* DEVICE_ID = "ESP1";
const char* RTDB_URL = "https://hospital-dashboard-d5d1b-default-rtdb.asia-southeast1.firebasedatabase.app/";

// ================= VARIABLES =================
float weight_kg = 0;
float volume_ml = 0;

float calibration = 270300;

float max_volume = 100.0;
float percentage = 0.0;
String statusText = "INIT";

// ================= OLED =================
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// ================= PINS =================
#define DT 18
#define SCK 19

#define BUZZER 5
#define LED1 32
#define LED2 14

// ================= WIFI =================
const char* ssid = "MVHS_EXT";
const char* password = "gt25233040";

HX711 scale;

unsigned long lastUpload = 0;
unsigned long lastDisplay = 0;
unsigned long lastBlink = 0;
unsigned long lastBuzz = 0;

float lastSentVolume = 0;

bool ledState = false;
bool buzzerState = false;

// ================= FAST READ =================
float fast_read() {
  if (scale.is_ready()) {
    return scale.get_units(3);
  }
  return weight_kg;
}

// ================= DISPLAY =================
void drawCentered(String line1, String line2) {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);

  int16_t x1, y1;
  uint16_t w, h;

  display.getTextBounds(line1, 0, 0, &x1, &y1, &w, &h);
  display.setCursor((128 - w) / 2, 20);
  display.print(line1);

  display.getTextBounds(line2, 0, 0, &x1, &y1, &w, &h);
  display.setCursor((128 - w) / 2, 40);
  display.print(line2);

  display.display();
}

// =========================================================
void setup() {
  Serial.begin(115200);
  delay(1000);

  Wire.begin(33, 25);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED not found");
    while (true);
  }

  pinMode(BUZZER, OUTPUT);
  pinMode(LED1, OUTPUT);
  pinMode(LED2, OUTPUT);

  drawCentered("Smart IV Boot", "Initializing");

  scale.begin(DT, SCK);
  scale.set_scale(calibration);

  drawCentered("Taring...", "Keep hook only");
  delay(5000);
  scale.tare();

  drawCentered("Connecting WiFi", "");
  Serial.print("[WIFI] Connecting");

  WiFi.begin(ssid, password);
  WiFi.setSleep(false);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    attempts++;
    Serial.print(".");
    drawCentered("Connecting WiFi", "Try: " + String(attempts));
    if (attempts > 40) ESP.restart();
  }

  Serial.println("\n[WIFI] Connected");
  drawCentered("WiFi Connected", "");
  delay(1000);
}

// =========================================================
int firebaseRequest(const String& path, const String& json) {
  HTTPClient http;
  String url = String(RTDB_URL) + path + ".json";

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  int code = http.PUT(json);
  http.end();

  return code;
}

// =========================================================
void loop() {

  if (WiFi.status() != WL_CONNECTED) {
    WiFi.begin(ssid, password);
  }

  // -------- READ --------
  float reading = fast_read();
  if (abs(reading) < 0.001) reading = 0;

  weight_kg = reading;
  volume_ml = weight_kg * 1000.0;
  percentage = (volume_ml / max_volume) * 100.0;

  // -------- STATUS --------
  if (percentage >= 50) statusText = "NORMAL";
  else if (percentage >= 20) statusText = "LOW";
  else statusText = "CRITICAL";

  // -------- ALERT SYSTEM --------
  if (percentage < 20) {

    // 🔊 Pulsed buzzer (soft beeps)
    if (millis() - lastBuzz > (buzzerState ? 50 : 250)) {
      lastBuzz = millis();
      buzzerState = !buzzerState;
      digitalWrite(BUZZER, buzzerState);
    }

    // 🔴 Alternate blinking LEDs
    if (millis() - lastBlink > 30) {
      lastBlink = millis();
      ledState = !ledState;

      digitalWrite(LED1, ledState);
      digitalWrite(LED2, !ledState);
    }

  } else {
    digitalWrite(BUZZER, LOW);
    digitalWrite(LED1, LOW);
    digitalWrite(LED2, LOW);
  }

  // -------- SERIAL --------
  Serial.print("Volume: ");
  Serial.print(volume_ml, 1);
  Serial.print(" mL | ");
  Serial.print(percentage, 1);
  Serial.print(" % | ");
  Serial.println(statusText);

  // -------- OLED --------
  if (millis() - lastDisplay > 500) {
    lastDisplay = millis();

    String line1 = String((int)volume_ml) + "mL " + String((int)percentage) + "% ";
    line1 += (WiFi.status() == WL_CONNECTED) ? "W" : "X";

    drawCentered(line1, statusText);
  }

  // -------- FIREBASE --------
  if (millis() - lastUpload > 300 && WiFi.status() == WL_CONNECTED) {
    lastUpload = millis();

    if (abs(volume_ml - lastSentVolume) > 1.0) {
      lastSentVolume = volume_ml;

      String json = "{\"weight\":" + String(weight_kg, 3) +
                    ",\"percentage\":" + String(percentage, 1) +
                    ",\"ts\":" + String(millis()) + "}";

      firebaseRequest("devices/" + String(DEVICE_ID) + "/latest", json);

      Serial.println("[FIREBASE FAST]");
    }
  }

  delay(50);
}
